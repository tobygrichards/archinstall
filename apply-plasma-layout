#!/usr/bin/env bash
# apply-plasma-layout — applies the panel layout ONCE on first login, then
# removes its own autostart entry so it never runs again. Mirrors the EFI
# first-boot pattern: a one-shot for the thing that can only happen in the
# live session (plasmashell must be running to script it — can't be done in
# the chroot at build time).
#
# Idempotent: the layout script itself clears existing panels first, so even
# if this runs twice it won't duplicate.

set -euo pipefail

LAYOUT="$HOME/.local/share/plasma-layout/panels-layout.js"
AUTOSTART="$HOME/.config/autostart/apply-plasma-layout.desktop"

# wait for plasmashell to be up (first login can race the autostart)
for i in $(seq 1 30); do
    if qdbus6 org.kde.plasmashell >/dev/null 2>&1; then break; fi
    sleep 1
done

if [[ -f "$LAYOUT" ]]; then
    qdbus6 org.kde.plasmashell /PlasmaShell org.kde.PlasmaShell.evaluateScript \
        "$(cat "$LAYOUT")" || true
fi

# one-shot: remove the autostart entry so this never runs again
rm -f "$AUTOSTART"
